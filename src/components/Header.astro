---
---
<header class="site-header">
  <div class="container header-content">
    <a href="/" class="logo">Fluly</a>
    <nav class="main-nav" id="mobileMenu">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/features">Features</a></li>
        <li><a href="/blog">Blog</a></li>

        <li class="nav-dropdown">
          <a href="/learn" class="nav-dropdown-trigger">Languages</a>
          <ul class="nav-dropdown-menu" role="menu">
            <li role="none"><a href="/learn/french" role="menuitem">🇫🇷 French</a></li>
            <li role="none"><a href="/learn/german" role="menuitem">🇩🇪 German</a></li>
            <li role="none"><a href="/learn/spanish" role="menuitem">🇪🇸 Spanish</a></li>
          </ul>
        </li>

        <li><a href="/community">Community</a></li>
        <li><a href="/pricing">Pricing</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </nav>
    <div class="header-actions">
      <a href="https://app.fluly.io/" class="btn btn-primary header-cta">Use on Web</a>
    </div>
    <button class="mobile-menu-toggle" id="menuToggle" aria-label="Menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</header>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const mobileMenu = document.getElementById('mobileMenu');

  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('active');
    menuToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });

  // Close menu when a link is clicked
  const menuLinks = mobileMenu?.querySelectorAll('a');
  menuLinks?.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('active');
      menuToggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // Mobile: toggle dropdown on tap of the Languages trigger
  const langTrigger = document.querySelector('.nav-dropdown-trigger');
  const langMenu = document.querySelector('.nav-dropdown-menu');

  langTrigger?.addEventListener('click', (e) => {
    // Only intercept on mobile (where hover doesn't work)
    if (window.innerWidth <= 768) {
      e.preventDefault();
      langMenu?.classList.toggle('open');
    }
  });
</script>

<style>
  /* ── Sticky glassmorphism header ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background-color: rgba(30, 27, 75, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0.875rem 0;
    transition: background-color 0.35s ease;
  }

  /* ── Layout ── */
  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* ── Logo ── */
  .logo {
    position: relative;
    font-size: 1.4rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.04em;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .logo::after {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    background-color: #D97706;
    border-radius: 50%;
    margin-left: 2px;
    vertical-align: super;
    position: relative;
    top: -2px;
  }

  .logo:hover {
    opacity: 0.85;
  }

  /* ── Navigation ── */
  .main-nav ul {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .main-nav a {
    position: relative;
    color: #94A3B8;
    font-weight: 500;
    font-size: 0.925rem;
    text-decoration: none;
    padding-bottom: 4px;
    transition: color 0.25s ease;
  }

  .main-nav a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 1.5px;
    background-color: #ffffff;
    transition: width 0.3s ease, left 0.3s ease;
    border-radius: 1px;
  }

  .main-nav a:hover {
    color: #ffffff;
  }

  .main-nav a:hover::after {
    width: 100%;
    left: 0;
  }

  /* ── Languages Dropdown ── */
  .nav-dropdown {
    position: relative;
  }

  /* Suppress the underline animation on the dropdown trigger —
     it's a hub link so the hover underline still works, but we
     don't want it competing visually with the dropdown panel */
  .nav-dropdown-trigger::after {
    display: none;
  }

  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    background: rgba(20, 18, 58, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(168, 157, 255, 0.15);
    border-radius: 12px;
    padding: 0.5rem;
    min-width: 180px;
    list-style: none;
    margin: 0;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 100;
  }

  /* Show on hover (desktop) */
  .nav-dropdown:hover .nav-dropdown-menu,
  .nav-dropdown-menu.open {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .nav-dropdown-menu li {
    margin: 0;
  }

  .nav-dropdown-menu a {
    display: block;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    color: #CBD5E1;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
    padding-bottom: 0.6rem; /* override the nav a padding-bottom: 4px */
  }

  .nav-dropdown-menu a::after {
    display: none;
  }

  .nav-dropdown-menu a:hover {
    background: rgba(168, 157, 255, 0.12);
    color: #ffffff;
  }

  /* ── Header CTA (smaller than page buttons) ── */
  .header-actions {
    display: flex;
    align-items: center;
  }

  .header-cta {
    font-size: 0.85rem;
    padding: 0.6rem 1.4rem;
  }

  /* ── Mobile hamburger ── */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    -webkit-tap-highlight-color: transparent;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background-color: #94A3B8;
    border-radius: 2px;
    transition: background-color 0.2s ease;
  }

  .mobile-menu-toggle:hover .hamburger-line {
    background-color: #ffffff;
  }

  /* ── Mobile menu styles ── */
  .main-nav.active {
    display: block !important;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background-color: rgba(30, 27, 75, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1rem 1.5rem;
    z-index: 999;
  }

  .main-nav.active ul {
    flex-direction: column;
    gap: 1rem;
  }

  .main-nav.active a {
    font-size: 1rem;
    padding: 0.5rem 0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .site-header {
      position: relative;
    }

    .main-nav {
      display: none;
    }

    .header-actions {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }

    /* Mobile dropdown: render inline */
    .nav-dropdown-menu {
      position: static;
      transform: none;
      background: rgba(168, 157, 255, 0.05);
      border: 1px solid rgba(168, 157, 255, 0.1);
      border-radius: 8px;
      margin-top: 0.5rem;
      opacity: 0;
      max-height: 0;
      overflow: hidden;
      visibility: hidden;
      transition: opacity 0.2s ease, max-height 0.25s ease, visibility 0.2s;
      box-shadow: none;
    }

    .nav-dropdown-menu.open {
      opacity: 1;
      visibility: visible;
      max-height: 200px;
      transform: none;
    }

    /* Disable CSS hover on mobile — only JS .open class applies */
    .nav-dropdown:hover .nav-dropdown-menu:not(.open) {
      opacity: 0;
      visibility: hidden;
    }
  }
</style>
