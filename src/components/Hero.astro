---
---
<section class="hero">
  <div class="hero-glow hero-glow--top-right" aria-hidden="true"></div>
  <div class="hero-glow hero-glow--bottom-left" aria-hidden="true"></div>

  <div class="container hero-container">

    <!-- Left: Text Content -->
    <div class="hero-content">
      <span class="badge">The #1 way to learn languages faster</span>
      <h1>Learn a New Language <span class="text-gradient">Faster</span> and for <span class="text-gradient">Free</span></h1>
      <p class="hero-subtitle">
        Free language learning app using the immersion method.
      Learn French, Spanish, Japanese and 304+ more languages naturally.</p>
      <p class="hero-subtitle">
      Learn With real movies, books, games, and podcasts.
        No textbook drills. Free on iOS and Android.
        Fluly is the fastest way to learn a language. Stop wasting time with
        traditional methods and start speaking with confidence today.
      </p>
      <div class="hero-cta">
        <a href="https://apps.apple.com/vn/app/linguaflow-learn-a-language/id6758226008" class="btn btn-accent">Download on App Store</a>
        <a href="https://github.com/reikomlive/download-fluly/releases/download/1.2.3/Fluly-arm64-v8a-release.apk" class="btn btn-accent">Download on Android</a>
        <a href="/learn-more" class="btn btn-outline">Learn More</a>
      </div>
      <p class="hero-trust">★★★★★ Rated 5 on the App Store</p>
    </div>

    <!-- Right: Mascot + Card Stack -->
    <div class="hero-visual">

      <!-- Mascot above card -->
      <div class="hero-mascot" aria-hidden="true">
        <svg width="100%" viewBox="0 0 680 500" role="img" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="340" cy="418" rx="105" ry="15" fill="#7C3AED" opacity="0.14"/>
          <path d="M 340 160 C 395 152 458 182 466 238 C 474 294 458 355 418 383 C 390 403 350 410 308 400 C 262 388 222 354 214 300 C 206 246 228 192 278 168 C 300 157 322 163 340 160 Z" fill="#7C3AED"/>
          <ellipse cx="374" cy="207" rx="50" ry="32" fill="#9F67F0" opacity="0.38" transform="rotate(-18 374 207)"/>
          <circle cx="305" cy="268" r="26" fill="white"/>
          <circle cx="308" cy="272" r="15" fill="#1a0533"/>
          <circle cx="301" cy="264" r="5.5" fill="white"/>
          <circle cx="376" cy="268" r="26" fill="white"/>
          <circle cx="379" cy="272" r="15" fill="#1a0533"/>
          <circle cx="372" cy="264" r="5.5" fill="white"/>
          <path d="M 312 318 Q 341 342 370 318" stroke="white" stroke-width="3.5" fill="none" stroke-linecap="round"/>
          <ellipse cx="284" cy="302" rx="17" ry="10" fill="#F9A8D4" opacity="0.48"/>
          <ellipse cx="396" cy="302" rx="17" ry="10" fill="#F9A8D4" opacity="0.48"/>
          <path d="M 198 268 Q 191 283 198 298" stroke="#A78BFA" stroke-width="2.5" fill="none" stroke-linecap="round"/>
          <path d="M 184 256 Q 174 283 184 310" stroke="#A78BFA" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.7"/>
          <path d="M 170 244 Q 157 283 170 322" stroke="#A78BFA" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.45"/>
          <path d="M 482 268 Q 489 283 482 298" stroke="#A78BFA" stroke-width="2.5" fill="none" stroke-linecap="round"/>
          <path d="M 496 256 Q 506 283 496 310" stroke="#A78BFA" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.7"/>
          <path d="M 510 244 Q 523 283 510 322" stroke="#A78BFA" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.45"/>
          <rect x="90" y="160" width="88" height="32" rx="16" fill="#6D28D9"/>
          <path d="M 166 190 L 180 200 L 158 194 Z" fill="#6D28D9"/>
          <text x="134" y="181" text-anchor="middle" fill="white" font-size="13" font-weight="500">Bonjour</text>
          <rect x="502" y="150" width="78" height="32" rx="16" fill="#4F46E5"/>
          <path d="M 514 180 L 500 200 L 522 190 Z" fill="#4F46E5"/>
          <text x="541" y="171" text-anchor="middle" fill="white" font-size="13" font-weight="500">¡Hola!</text>
          <rect x="291" y="428" width="98" height="32" rx="16" fill="#7C3AED" opacity="0.88"/>
          <text x="340" y="449" text-anchor="middle" fill="white" font-size="13" font-weight="500">Ciao! 👋</text>
        </svg>
      </div>

      <!-- Back card -->
      <div class="card card--back" aria-hidden="true">
        <div class="card__header"></div>
        <div class="card__body">
          <div class="card__row"></div>
          <div class="card__row card__row--short"></div>
        </div>
      </div>

      <!-- Main card -->
      <div class="card card--main">
        <div class="card__header">
          <span class="card__header-dot"></span>
          <span class="card__header-title">Today's Top Language</span>
        </div>
        <div class="card__body">
          <div class="card__lesson">
            <span class="card__lesson-emoji">🇫🇷</span>
            <div>
              <p class="card__lesson-title">French - Bonjour</p>
              <p class="card__lesson-meta">How to greet in French</p>
            </div>
          </div>
          <div class="card__progress">
            <div class="card__progress-bar">
              <div class="card__progress-fill"></div>
            </div>
            <span class="card__progress-label">80%</span>
          </div>
          <div class="card__lesson">
            <span class="card__lesson-emoji">🗣️</span>
            <div>
              <p class="card__lesson-title">Speaking Practice</p>
              <p class="card__lesson-meta">Learners are speaking to each other</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Streak badge -->
      <div class="card card--badge">
        <span class="card--badge__fire">🔥</span>
        <div>
          <p class="card--badge__label">Top Learner Streak</p>
          <p class="card--badge__value">15</p>
        </div>
      </div>

    </div>
  </div>

  <!-- Screenshot row — full width below hero columns -->
<div class="hero-screenshots">
  <div class="screenshot-item">
    <img src="/images/fluly_home_lessons.webp" alt="Fluly home screen with guided courses" width="180" height="320" loading="lazy"/>
  </div>
  <div class="screenshot-item screenshot-item--raised">
    <img src="/images/instant_definitions.webp" alt="Fluly instant word definitions feature" width="180" height="320" loading="lazy"/>
  </div>
  <div class="screenshot-item">
    <img src="/images/practice_speaking.webp" alt="Fluly speaking practice feature" width="180" height="320" loading="lazy"/>
  </div>
  <div class="screenshot-item screenshot-item--raised">
    <img src="/images/vocabulary_quiz.webp" alt="Fluly vocabulary quiz feature" width="180" height="320" loading="lazy"/>
  </div>
</div>
</section>

<style>
  /* -------------------------------------------------- */
  /*  HERO                                              */
  /* -------------------------------------------------- */
  .hero {
    position: relative;
    padding: 10rem 0 5rem;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .hero-glow--top-right {
    width: 900px; height: 900px;
    top: -20%; right: -15%;
    background: radial-gradient(circle, rgba(91,82,240,0.12) 0%, rgba(91,82,240,0.04) 40%, transparent 70%);
  }

  .hero-glow--bottom-left {
    width: 520px; height: 520px;
    bottom: -10%; left: -8%;
    background: radial-gradient(circle, rgba(124,111,255,0.10) 0%, rgba(124,111,255,0.03) 45%, transparent 70%);
  }

  .hero-container {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 55% 45%;
    gap: 3rem;
    align-items: center;
  }

  /* -------------------------------------------------- */
  /*  TEXT                                              */
  /* -------------------------------------------------- */
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-highlight-purple);
    background: rgba(91,82,240,0.12);
    border: 1px solid rgba(91,82,240,0.22);
    border-radius: 9999px;
    margin-bottom: 1.25rem;
  }

  h1 {
    font-size: 3.75rem;
    line-height: 1.08;
    font-weight: 800;
    letter-spacing: -0.025em;
    margin-bottom: 1.25rem;
    color: #ffffff;
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--color-brand-purple), var(--color-accent-gold));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    line-height: 1.7;
    color: #94A3B8;
    max-width: 480px;
    margin-bottom: 2.25rem;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .btn-outline {
    background: transparent;
    color: var(--color-light-purple);
    border: 1px solid var(--color-light-purple);
    padding: 0.875rem 1.75rem;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 1.125rem;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    text-decoration: none;
  }

  .btn-outline:hover {
    background: var(--color-light-purple);
    color: #ffffff;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(124,111,255,0.35);
  }

  .hero-trust {
    font-size: 0.85rem;
    color: #64748B;
    margin: 0;
  }

  /* -------------------------------------------------- */
  /*  VISUAL COLUMN                                     */
  /* -------------------------------------------------- */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 480px;
  }

  /* Mascot sits above the card */
  .hero-mascot {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 450px;
    z-index: 5;
    pointer-events: none;
  }

  /* -------------------------------------------------- */
  /*  CARDS                                             */
  /* -------------------------------------------------- */
  .card {
    border-radius: 20px;
    background: var(--color-detail-indigo);
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 20px 50px -12px rgba(0,0,0,0.45);
  }

  .card--main {
    position: relative;
    z-index: 3;
    width: 280px;
    animation: float 5s ease-in-out infinite;
  }

  .card__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .card__header-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-brand-purple);
    flex-shrink: 0;
  }

  .card__header-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: #e2e8f0;
  }

  .card__body {
    padding: 1.15rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .card__lesson {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .card__lesson-emoji { font-size: 1.6rem; line-height: 1; }

  .card__lesson-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: #e2e8f0;
    margin: 0;
  }

  .card__lesson-meta {
    font-size: 0.72rem;
    color: #64748B;
    margin: 0;
  }

  .card__progress {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .card__progress-bar {
    flex: 1;
    height: 6px;
    border-radius: 3px;
    background: rgba(255,255,255,0.08);
    overflow: hidden;
  }

  .card__progress-fill {
    width: 80%;
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--color-brand-purple), var(--color-accent-gold));
  }

  .card__progress-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-accent-gold);
    flex-shrink: 0;
  }

  .card--back {
    position: absolute;
    z-index: 1;
    width: 280px;
    height: 260px;
    top: 18%; left: 50%;
    transform: translateX(-40%) rotate(3deg);
    opacity: 0.35;
  }

  .card--back .card__header { height: 44px; }

  .card--back .card__row {
    height: 12px;
    border-radius: 6px;
    background: rgba(255,255,255,0.06);
  }

  .card--back .card__row--short { width: 60%; }

  .card--badge {
    position: absolute;
    z-index: 4;
    bottom: 6%; right: 2%;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.65rem 1rem;
    border-radius: 14px;
    border: 1px solid rgba(252,211,77,0.22);
    box-shadow: 0 10px 30px -8px rgba(0,0,0,0.4);
    animation: float 5s ease-in-out 1.5s infinite;
  }

  .card--badge__fire { font-size: 1.25rem; line-height: 1; }

  .card--badge__label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #94A3B8;
    margin: 0;
    font-weight: 600;
  }

  .card--badge__value {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--color-accent-gold);
    line-height: 1.1;
    margin: 0;
  }

  /* -------------------------------------------------- */
  /*  SCREENSHOT ROW                                    */
  /* -------------------------------------------------- */
.hero-screenshots {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: flex-end;
  gap: 1.25rem;
  margin-top: 4rem;
  padding: 0 2rem 2rem;
}

  .screenshot-item {
    transition: transform 0.3s ease;
  }

  .screenshot-item:hover {
    transform: translateY(-8px);
  }

  /* Every other screenshot raised slightly */
  .screenshot-item--raised {
    transform: translateY(-20px);
  }

  .screenshot-item--raised:hover {
    transform: translateY(-28px);
  }

  .screenshot-item img {
    width: 260px;
    border-radius: 22px;
    box-shadow: 0 24px 48px -12px rgba(0,0,0,0.65);
    border: 1px solid rgba(255,255,255,0.08);
    display: block;
  }

  /* -------------------------------------------------- */
  /*  FLOAT ANIMATION                                   */
  /* -------------------------------------------------- */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-12px); }
  }

  /* -------------------------------------------------- */
  /*  RESPONSIVE                                        */
  /* -------------------------------------------------- */
  @media (max-width: 992px) {
    .hero { padding: 8rem 0 3rem; }

    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-content { align-items: center; }

    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-cta { justify-content: center; }

    h1 { font-size: 2.5rem; }

    .hero-visual { min-height: 360px; }

    .card--back,
    .card--badge { display: none; }

    .screenshot-item img { width: 120px; }
  }

  @media (max-width: 480px) {
    .hero { padding: 7rem 0 2rem; }

    h1 { font-size: 2rem; }

    .hero-subtitle { font-size: 1rem; }

    .card--main { width: 250px; }

    .hero-screenshots { gap: 0.75rem; }

    .screenshot-item img { width: 80px; border-radius: 14px; }
  }
</style>