---
// Footer.astro – Site footer
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- ── Top grid ── -->
    <div class="footer-grid">
      <!-- Brand column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          fluly<span class="logo-dot">.</span>
        </a>
        <p class="footer-tagline">
          AI-powered language learning that fits your life.
        </p>
        <div class="social-links">
          <a href="#" class="social-icon" aria-label="Twitter">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
              <text x="10" y="14" text-anchor="middle" fill="currentColor" font-size="10" font-family="sans-serif">𝕏</text>
            </svg>
          </a>
          <a href="#" class="social-icon" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="10" cy="10" r="3.5" stroke="currentColor" stroke-width="1.3"/>
              <circle cx="14.5" cy="5.5" r="1" fill="currentColor"/>
            </svg>
          </a>
          <a href="#" class="social-icon" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
              <text x="10" y="14" text-anchor="middle" fill="currentColor" font-size="10" font-weight="700" font-family="sans-serif">in</text>
            </svg>
          </a>
          <a href="#" class="social-icon" aria-label="TikTok">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
              <text x="10" y="14" text-anchor="middle" fill="currentColor" font-size="9" font-family="sans-serif">♪</text>
            </svg>
          </a>
        </div>
      </div>

      <!-- Product column -->
      <div class="footer-col">
        <h4 class="footer-heading">Product</h4>
        <ul>
          <li><a href="/#features">Features</a></li>
        
          <li><a href="/pricing">Pricing</a></li>
        
        </ul>
      </div>

      <!-- Resources column -->
      <div class="footer-col">
        <h4 class="footer-heading">Resources</h4>
        <ul>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/help">Help Center</a></li>
          <li><a href="/community">Community</a></li>
     
        </ul>
      </div>

      <!-- Legal column -->
      <div class="footer-col">
        <h4 class="footer-heading">Legal</h4>
        <ul>
          <li><a href="/privacy">Privacy Policy</a></li>
          <li><a href="/terms">Terms of Service</a></li>
          <li><a href="/cookies">Cookie Policy</a></li>
        </ul>
      </div>
    </div>

    <!-- ── Divider ── -->
    <hr class="footer-divider" />

    <!-- ── Bottom bar ── -->
    <div class="footer-bottom">
      <p class="copyright">© {currentYear} fluly. All rights reserved.</p>
      <p class="made-with">Made with ❤️ for language learners</p>
    </div>
  </div>
</footer>

<style>
  /* ── Footer base ── */
  .site-footer {
    background: #0F0E24;
    color: #94A3B8;
    padding: 4.5rem 1.5rem 2rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Top grid: 4 columns ── */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 3rem 2.5rem;
  }

  /* ── Brand column ── */
  .footer-logo {
    font-size: 1.45rem;
    font-weight: 800;
    color: #ffffff;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 0.75rem;
  }

  .logo-dot {
    color: #D97706;
  }

  .footer-tagline {
    font-size: 0.92rem;
    line-height: 1.55;
    color: #64748B;
    margin-bottom: 1.25rem;
    max-width: 240px;
  }

  /* Social icons */
  .social-links {
    display: flex;
    gap: 0.65rem;
  }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #64748B;
    transition: color 0.2s ease;
  }

  .social-icon:hover {
    color: #A89DFF;
  }

  /* ── Link columns ── */
  .footer-heading {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #94A3B8;
    margin: 0 0 1.25rem;
  }

  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .footer-col a {
    color: #64748B;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .footer-col a:hover {
    color: #A89DFF;
  }

  /* ── Divider ── */
  .footer-divider {
    border: none;
    border-top: 1px solid rgba(148, 163, 184, 0.1);
    margin: 3rem 0 1.5rem;
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .copyright {
    font-size: 0.82rem;
    color: #475569;
    margin: 0;
  }

  .made-with {
    font-size: 0.82rem;
    color: #475569;
    margin: 0;
  }

  /* ── Responsive ── */

  /* Tablet: 2×2 grid for link cols, brand stays full-width */
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  /* Mobile: single column */
  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }
  }
</style>
