---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Fluly Pro - Pricing">
  <main class="pricing-container">

    <!-- Hero -->
    <section class="pricing-hero">
      <div class="container">
        <span class="hero-badge">Fluly Pro</span>
        <h1>Learn faster.<br/><span class="text-gradient">Go Pro.</span></h1>
        <p class="hero-subtitle">
          Fluly is free to use. Pro unlocks the full experience - 
          no limits, no ads, no artificial caps on your learning.
        </p>
      </div>
    </section>

    <!-- Plans -->
    <section class="plans-section">
      <div class="container">

        <div class="plans-grid">

          <!-- Free -->
          <div class="plan-card plan-card--free">
            <div class="plan-header">
              <p class="plan-name">Free</p>
              <div class="plan-price">
                <span class="plan-amount">$0</span>
              </div>
              <p class="plan-tagline">Get started with the basics</p>
            </div>
            <ul class="plan-features">
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Access to core immersion tools</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Word-by-word translation</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Basic vocabulary tracking</span>
              </li>
              <li class="plan-feature plan-feature--excluded">
                <span class="feature-icon">✗</span>
                <span>Unlimited imports</span>
              </li>
              <li class="plan-feature plan-feature--excluded">
                <span class="feature-icon">✗</span>
                <span>Offline access</span>
              </li>
              <li class="plan-feature plan-feature--excluded">
                <span class="feature-icon">✗</span>
                <span>AI rewrite & practice sentences</span>
              </li>
              <li class="plan-feature plan-feature--excluded">
                <span class="feature-icon">✗</span>
                <span>Ad-free experience</span>
              </li>
            </ul>
            <a href="#" class="btn btn-outline">Download Free</a>
          </div>

          <!-- 1 Month -->
          <div class="plan-card">
            <div class="plan-header">
              <p class="plan-name">1 Month</p>
              <div class="plan-price">
                <span class="plan-amount">$9.99</span>
                <span class="plan-period">/month</span>
              </div>
              <p class="plan-tagline">Try Pro with full access</p>
            </div>
            <ul class="plan-features">
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Everything in Free</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Unlimited imports</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Offline access</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>AI rewrite & practice sentences</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Ad-free experience</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Flashcards & pronunciation practice</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Cancel anytime</span>
              </li>
            </ul>
            <a href="#" class="btn btn-accent">Get Started</a>
          </div>

          <!-- 6 Months -->
          <div class="plan-card plan-card--popular">
            <div class="plan-badge">Most Popular</div>
            <div class="plan-header">
              <p class="plan-name">6 Months</p>
              <div class="plan-price">
                <span class="plan-amount">$19.99</span>
              </div>
              <p class="plan-per-month">$3.33 / month</p>
              <p class="plan-tagline">Save 67% vs monthly</p>
            </div>
            <ul class="plan-features">
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Everything in Free</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Unlimited imports</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Offline access</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>AI rewrite & practice sentences</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Ad-free experience</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Flashcards & pronunciation practice</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Cancel anytime</span>
              </li>
            </ul>
            <a href="#" class="btn btn-accent">Get Started</a>
          </div>

          <!-- Lifetime -->
          <div class="plan-card plan-card--lifetime">
            <div class="plan-badge plan-badge--gold">Best Value</div>
            <div class="plan-header">
              <p class="plan-name">Lifetime</p>
              <div class="plan-price">
                <span class="plan-amount">$99.99</span>
              </div>
              <p class="plan-tagline">Pay once, learn forever</p>
            </div>
            <ul class="plan-features">
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Everything in Free</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Unlimited imports - forever</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Offline access - forever</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>AI rewrite & practice sentences</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Ad-free - forever</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>Flashcards & pronunciation practice</span>
              </li>
              <li class="plan-feature plan-feature--included">
                <span class="feature-icon">✓</span>
                <span>All future features included</span>
              </li>
            </ul>
            <a href="#" class="btn btn-gold">Get Lifetime Access</a>
          </div>

        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="benefits-section">
      <div class="container">
        <span class="section-label">Why Pro</span>
        <h2>What you unlock</h2>
        <div class="benefits-grid">
          <div class="benefit-card">
      
            <h3>Learn from real content</h3>
            <p>Import movies, TV shows, YouTube videos, books, and articles and turn them into interactive lessons.</p>
          </div>
          <div class="benefit-card">
         
            <h3>Learn faster with immersion</h3>
            <p>Stop memorizing lists. Build vocabulary and comprehension naturally, in context, the way native speakers do.</p>
          </div>
          <div class="benefit-card">
        
            <h3>No limits, no restrictions</h3>
            <p>Unlimited imports, unlimited learning - no daily caps, no artificial limits on your progress.</p>
          </div>
          <div class="benefit-card">
           
            <h3>More languages, better features</h3>
            <p>Your subscription helps add new languages, improve learning tools, and keep the servers running.</p>
          </div>
          <div class="benefit-card">
       
            <h3>Distraction-free</h3>
            <p>An ad-free experience designed for deep, focused learning. No ads interrupting your flow state.</p>
          </div>
          <div class="benefit-card">
           
            <h3>More tools</h3>
            <p>AI rewrite, offline access, flashcards, pronunciation practice, and more coming soon.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Mascot CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-inner">
          <div class="cta-mascot" aria-hidden="true">
            <svg width="140" viewBox="0 0 680 500" xmlns="http://www.w3.org/2000/svg">
              <ellipse cx="340" cy="418" rx="105" ry="15" fill="#7C3AED" opacity="0.14"/>
              <path d="M 340 160 C 395 152 458 182 466 238 C 474 294 458 355 418 383 C 390 403 350 410 308 400 C 262 388 222 354 214 300 C 206 246 228 192 278 168 C 300 157 322 163 340 160 Z" fill="#7C3AED"/>
              <ellipse cx="374" cy="207" rx="50" ry="32" fill="#9F67F0" opacity="0.38" transform="rotate(-18 374 207)"/>
              <circle cx="305" cy="268" r="26" fill="white"/>
              <circle cx="308" cy="272" r="15" fill="#1a0533"/>
              <circle cx="301" cy="264" r="5.5" fill="white"/>
              <circle cx="376" cy="268" r="26" fill="white"/>
              <circle cx="379" cy="272" r="15" fill="#1a0533"/>
              <circle cx="372" cy="264" r="5.5" fill="white"/>
              <path d="M 312 318 Q 341 342 370 318" stroke="white" stroke-width="3.5" fill="none" stroke-linecap="round"/>
              <ellipse cx="284" cy="302" rx="17" ry="10" fill="#F9A8D4" opacity="0.48"/>
              <ellipse cx="396" cy="302" rx="17" ry="10" fill="#F9A8D4" opacity="0.48"/>
              <path d="M 198 268 Q 191 283 198 298" stroke="#A78BFA" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              <path d="M 184 256 Q 174 283 184 310" stroke="#A78BFA" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.7"/>
              <path d="M 482 268 Q 489 283 482 298" stroke="#A78BFA" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              <path d="M 496 256 Q 506 283 496 310" stroke="#A78BFA" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.7"/>
              <rect x="291" y="428" width="98" height="32" rx="16" fill="#7C3AED" opacity="0.88"/>
              <text x="340" y="449" text-anchor="middle" fill="white" font-size="13" font-weight="500">Ciao! 👋</text>
            </svg>
          </div>
          <div class="cta-text">
            <h2>Start learning the way it actually works</h2>
            <p>Learn from content you already enjoy. Study at your own pace. Cancel anytime.</p>
            <div class="cta-buttons">
              <a href="#" class="btn btn-accent">Download on App Store</a>
              <a href="https://github.com" class="btn btn-outline">Get APK on GitHub</a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  .pricing-container {
    background-color: var(--color-deep-indigo, #1E1B4B);
    color: #e5e7eb;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-gold, #FCD34D);
    margin-bottom: 1rem;
  }

  /* -------------------------------------------------- */
  /*  HERO                                              */
  /* -------------------------------------------------- */
  .pricing-hero {
    padding: 8rem 1.5rem 5rem;
    text-align: center;
    background: linear-gradient(160deg, #2D2A6E 0%, #1E1B4B 100%);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-highlight-purple, #A89DFF);
    background: rgba(91,82,240,0.12);
    border: 1px solid rgba(91,82,240,0.22);
    border-radius: 9999px;
    padding: 0.35rem 1rem;
    margin-bottom: 1.5rem;
  }

  .pricing-hero h1 {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin-bottom: 1.25rem;
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--color-brand-purple, #5B52F0), var(--color-accent-gold, #FCD34D));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: #94A3B8;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* -------------------------------------------------- */
  /*  PLANS                                             */
  /* -------------------------------------------------- */
  .plans-section {
    padding: 5rem 1.5rem;
  }

  .plans-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    align-items: start;
  }

  .plan-card {
    position: relative;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .plan-card:hover {
    transform: translateY(-4px);
  }

  .plan-card--free {
    opacity: 0.85;
  }

  .plan-card--popular {
    border-color: rgba(91,82,240,0.5);
    background: rgba(91,82,240,0.08);
    transform: translateY(-8px);
  }

  .plan-card--popular:hover {
    transform: translateY(-12px);
  }

  .plan-card--lifetime {
    border-color: rgba(252,211,77,0.3);
    background: rgba(252,211,77,0.04);
  }

  .plan-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-brand-purple, #5B52F0);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 9999px;
    white-space: nowrap;
  }

  .plan-badge--gold {
    background: linear-gradient(135deg, #D97706, #FCD34D);
    color: #1E1B4B;
  }

  .plan-name {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #64748B;
    margin: 0 0 0.5rem;
  }

  .plan-amount {
    font-size: 2.5rem;
    font-weight: 800;
    color: #ffffff;
    line-height: 1;
  }

  .plan-period {
    font-size: 1rem;
    color: #64748B;
    font-weight: 400;
  }

  .plan-per-month {
    font-size: 0.85rem;
    color: var(--color-accent-gold, #FCD34D);
    margin: 0.25rem 0 0;
    font-weight: 600;
  }

  .plan-tagline {
    font-size: 0.85rem;
    color: #64748B;
    margin: 0.25rem 0 0;
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .plan-feature {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.88rem;
    line-height: 1.4;
  }

  .plan-feature--included {
    color: #e2e8f0;
  }

  .plan-feature--excluded {
    color: #475569;
  }

  .feature-icon {
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .plan-feature--included .feature-icon {
    color: var(--color-brand-purple, #5B52F0);
  }

  .plan-feature--excluded .feature-icon {
    color: #334155;
  }

  /* -------------------------------------------------- */
  /*  BUTTONS                                           */
  /* -------------------------------------------------- */
  .btn {
    display: block;
    text-align: center;
    padding: 0.875rem 1.5rem;
    border-radius: 9999px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-accent {
    background: linear-gradient(135deg, var(--color-brand-purple, #5B52F0), var(--color-light-purple, #7C6FFF));
    color: white;
  }

  .btn-accent:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(91,82,240,0.4);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-light-purple, #7C6FFF);
    border: 1px solid rgba(124,111,255,0.4);
  }

  .btn-outline:hover {
    background: rgba(124,111,255,0.1);
    border-color: var(--color-light-purple, #7C6FFF);
  }

  .btn-gold {
    background: linear-gradient(135deg, #D97706, #FCD34D);
    color: #1E1B4B;
    font-weight: 800;
  }

  .btn-gold:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(252,211,77,0.3);
  }

  /* -------------------------------------------------- */
  /*  BENEFITS                                          */
  /* -------------------------------------------------- */
  .benefits-section {
    padding: 5rem 1.5rem;
    background: rgba(45,42,110,0.3);
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .benefits-section h2 {
    font-size: 2rem;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 3rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .benefit-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    padding: 1.75rem;
    transition: all 0.3s ease;
  }

  .benefit-card:hover {
    background: rgba(91,82,240,0.08);
    border-color: rgba(91,82,240,0.2);
    transform: translateY(-3px);
  }



  .benefit-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #e2e8f0;
    margin-bottom: 0.5rem;
  }

  .benefit-card p {
    font-size: 0.88rem;
    color: #64748B;
    line-height: 1.6;
    margin: 0;
  }

  /* -------------------------------------------------- */
  /*  CTA                                               */
  /* -------------------------------------------------- */
  .cta-section {
    padding: 6rem 1.5rem;
  }

  .cta-inner {
    display: flex;
    align-items: center;
    gap: 4rem;
    background: rgba(91,82,240,0.08);
    border: 1px solid rgba(91,82,240,0.18);
    border-radius: 24px;
    padding: 3rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .cta-mascot {
    flex-shrink: 0;
  }

  .cta-text h2 {
    font-size: 1.75rem;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .cta-text p {
    font-size: 1rem;
    color: #94A3B8;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cta-buttons .btn {
    display: inline-block;
  }

  /* -------------------------------------------------- */
  /*  RESPONSIVE                                        */
  /* -------------------------------------------------- */
  @media (max-width: 1024px) {
    .plans-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .plan-card--popular {
      transform: none;
    }

    .plan-card--popular:hover {
      transform: translateY(-4px);
    }

    .benefits-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .pricing-hero h1 { font-size: 2.25rem; }

    .plans-grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin: 0 auto;
    }

    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .cta-inner {
      flex-direction: column;
      text-align: center;
      gap: 2rem;
    }

    .cta-buttons {
      justify-content: center;
      flex-direction: column;
      align-items: center;
    }

    .cta-buttons .btn {
      width: 100%;
      max-width: 300px;
    }
  }
</style>