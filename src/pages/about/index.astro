    background: linear-gradient(160deg, #2D2A6E 0%, #1E1B4B 100%);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-highlight-purple, #A89DFF);
    background: rgba(91,82,240,0.12);
    border: 1px solid rgba(91,82,240,0.22);
    border-radius: 9999px;
