    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(91,82,240,0.4);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-light-purple, #7C6FFF);
    border: 1px solid var(--color-light-purple, #7C6FFF);
  }

  .btn-outline:hover {
    background: var(--color-light-purple, #7C6FFF);
    color: white;
    transform: translateY(-2px);
  }

  .cta-note {
    font-size: 0.85rem;
    color: #64748B;
  }

  /* -------------------------------------------------- */
  /*  RESPONSIVE                                        */
  /* -------------------------------------------------- */
  @media (max-width: 1024px) {
    .method-steps,
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .about-hero h1 { font-size: 2rem; }

    .two-col,
    .mascot-content {
      grid-template-columns: 1fr;
      flex-direction: column;
    }

    .founder-card {
      flex-direction: column;
      text-align: center;
    }

    .method-steps,
    .features-grid {
      grid-template-columns: 1fr;
    }

    .mascot-svg {
      text-align: center;
    }

    .about-cta h2 { font-size: 1.75rem; }

    .cta-buttons { flex-direction: column; align-items: center; }

    .btn { width: 100%; max-width: 300px; text-align: center; }
  }
</style>