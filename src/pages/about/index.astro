    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: #ffffff;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .lead {
    font-size: 1.2rem;
    max-width: 680px;
    margin: 0 auto;
    color: #94A3B8;
    line-height: 1.8;
  }

  /* -------------------------------------------------- */
  /*  FOUNDER                                           */
  /* -------------------------------------------------- */
