    font-weight: 600;
  }
  
  .back-link:hover {
    color: var(--color-highlight-purple);
  }
  
  .post-header time {
    display: block;
    color: var(--color-brand-gold);
    margin-bottom: 1rem;
    font-weight: 600;
  }
  
  .post-header h1 {
    font-size: 3.5rem;
