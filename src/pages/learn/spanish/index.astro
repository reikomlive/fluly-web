    margin-bottom: 4rem;
  }
  
  .post-container {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--color-light-purple);
    font-weight: 600;
  }
  
  .back-link:hover {
    color: var(--color-highlight-purple);
  }
  
  .post-header time {
    display: block;
    color: var(--color-brand-gold);
    margin-bottom: 1rem;
    font-weight: 600;
  }
  
  .post-header h1 {
    font-size: 3.5rem;
    margin-bottom: 0;
    line-height: 1.1;
  }
  
  .post-content {
    font-size: 1.125rem;
    color: #E2E8F0;
    line-height: 1.8;
  }
  
  .post-content h2 {
    font-size: 2rem;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: #FFFFFF;
  }
  
  .post-content h3 {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #FFFFFF;
  }
  
  .post-content p {
    margin-bottom: 1.5rem;
  }

  .guide-links {
    display: flex;
    flex-direction: column;
