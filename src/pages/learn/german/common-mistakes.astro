const title = "5 Mistakes English Speakers Make Learning German";
const description = "The real, specific traps that stall English speakers learning German — from fighting verb-final word order to freezing over the Sie/du decision — and what to do instead.";
const publishDate = new Date('2026-06-13');
---

<Layout title={title} description={description} isBlogPost={true} publishDate={publishDate} slug="/learn/german/common-mistakes">
  <article class="blog-post">
    <header class="post-header glow-purple">
      <div class="container post-container">
        <a href="/learn/german" class="back-link">&larr; Back to German Hub</a>
        <time datetime={publishDate.toISOString()}>June 13, 2026</time>
