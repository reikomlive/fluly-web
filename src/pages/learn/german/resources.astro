    margin-top: 3rem;
    margin-bottom: 1.5rem;
    color: #FFFFFF;
  }
  
  .post-content p {
    margin-bottom: 1.5rem;
  }

  .post-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .post-content li {
    margin-bottom: 0.75rem;
  }

  .post-content strong {
    color: #A78BFA;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 2.5rem;
    }
  }
</style>
