---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import BlogCard from '../components/BlogCard.astro';
import Cta from '../components/Cta.astro';
import type { ImageMetadata } from 'astro';

import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const recentPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);

// Import all images from blog folders
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/blog/*/*.{webp,png,jpg,jpeg,svg}',
  { eager: true }
);

// Helper function to get first image for a post
function getPostImage(slug: string) {
  // Find all images for this post
  const postImages = Object.keys(images)
    .filter(key => key.includes(`/src/content/blog/${slug}/`))
    .sort(); // Sort to get consistent first image
  
  return postImages.length > 0 ? images[postImages[0]].default : undefined;
}
---

<Layout title="Learn any Language Fast & Free | Immersion Method">
  <Hero />
  <Features />
  
  <section class="blog-preview">
    <div class="container">
      <div class="section-header">
        <h2>Latest from the Blog</h2>
        <a href="/blog" class="view-all">View all articles &rarr;</a>
      </div>
      
      <div class="blog-grid">
        {recentPosts.map(post => (
          <BlogCard 
            title={post.data.title}
            excerpt={post.data.excerpt}
            slug={post.id}
            date={post.data.date.toISOString()}
            image={getPostImage(post.id)}
          />
        ))}
      </div>
    </div>
  </section>
  
  <Cta />
</Layout>

<style>
  .blog-preview {
    background-color: #151336;
  }
  
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }
  
  .section-header h2 {
    font-size: 2.5rem;
    margin-bottom: 0;
  }
  
  .view-all {
    font-weight: 600;
    color: var(--color-light-purple);
  }
  
  .view-all:hover {
    color: var(--color-highlight-purple);
  }
  
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  
  @media (max-width: 992px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 768px) {
    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
