---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const communities = await getCollection('community');
---

<Layout title="Language Learning WhatsApp Groups | Join Our Community" description="Join active WhatsApp groups for learning languages with native speakers. Practice your target language daily with real people in supportive language learning communities.">
  <main class="community-container">

    <!-- Hero -->
    <section class="communities-hero">
      <div class="container">
        <span class="hero-badge">Community</span>
        <h1>Learn Languages on WhatsApp with Our Community</h1>
        <p class="lead">
          Join active <strong>WhatsApp groups for language learning</strong> where you can practice your target language daily with native speakers and learners worldwide. Find your language community, practice real conversations, and accelerate your fluency on WhatsApp.
        </p>
      </div>
    </section>

    <!-- Communities List -->
    <section class="communities-section">
      <div class="container">
        {communities.length > 0 ? (
          <div class="communities-grid">
            {communities.map((community) => (
              <a href={`/community/${community.id}`} class="community-card">
                <div class="community-card__header">
                  <h3>{community.data.title}</h3>
                  <span class="language-tag">{community.data.language}</span>
                </div>
                <p class="community-card__description">
                  {community.data.description}
                </p>
                {community.data.whatsappLink && (
                  <div class="community-card__cta">
                    💬 Join on WhatsApp →
                  </div>
                )}
              </a>
            ))}
          </div>
        ) : (
          <div class="no-communities">
            <p>Communities coming soon! Check back later.</p>
          </div>
        )}
      </div>
    </section>

  </main>
</Layout>

<style>
  .community-container {
    background-color: var(--color-deep-indigo, #1E1B4B);
    color: #e5e7eb;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* -------------------------------------------------- */
  /*  HERO                                              */
  /* -------------------------------------------------- */
  .communities-hero {
    padding: 8rem 1.5rem 5rem;
    text-align: center;
    background: linear-gradient(160deg, #2D2A6E 0%, #1E1B4B 100%);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-highlight-purple, #A89DFF);
    background: rgba(91,82,240,0.12);
    border: 1px solid rgba(91,82,240,0.22);
    border-radius: 9999px;
    padding: 0.35rem 1rem;
    margin-bottom: 1.5rem;
  }

  .communities-hero h1 {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: #ffffff;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .lead {
    font-size: 1.2rem;
    max-width: 680px;
    margin: 0 auto;
    color: #94A3B8;
    line-height: 1.8;
  }

  /* -------------------------------------------------- */
  /*  COMMUNITIES GRID                                  */
  /* -------------------------------------------------- */
  .communities-section {
    padding: 5rem 1.5rem;
    min-height: 60vh;
  }

  .communities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .community-card {
    background: rgba(91, 82, 240, 0.06);
    border: 1px solid rgba(91, 82, 240, 0.18);
    border-radius: 16px;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .community-card:hover {
    background: rgba(91, 82, 240, 0.12);
    border-color: rgba(91, 82, 240, 0.35);
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(91, 82, 240, 0.15);
  }

  .community-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .community-card h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
  }

  .language-tag {
    display: inline-block;
    background: rgba(252, 211, 77, 0.15);
    color: var(--color-accent-gold, #FCD34D);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .community-card__description {
    color: #94A3B8;
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
  }

  .community-card__cta {
    color: var(--color-light-purple, #7C6FFF);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: gap 0.3s ease;
  }

  .community-card:hover .community-card__cta {
    gap: 0.75rem;
  }

  .no-communities {
    text-align: center;
    padding: 3rem;
    color: #94A3B8;
    font-size: 1.1rem;
  }

  /* -------------------------------------------------- */
  /*  RESPONSIVE                                        */
  /* -------------------------------------------------- */
  @media (max-width: 768px) {
    .communities-hero h1 {
      font-size: 2rem;
    }

    .lead {
      font-size: 1rem;
    }

    .communities-grid {
      grid-template-columns: 1fr;
    }
  }
</style>